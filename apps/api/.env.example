# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
API_VERSION=v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db
TURSO_DATABASE_URL=libsql://your-edgeflow-database.turso.io
TURSO_AUTH_TOKEN=replace-with-your-turso-auth-token
DATABASE_POOL_SIZE=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-at-least-64-chars-long-for-production-use
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-64-chars-long-for-production-use
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_REFRESH_EXPIRY_REMEMBER_ME=90d

# ─── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/github/callback

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@edgeflow.io
EMAIL_FROM_NAME=EdgeFlow

# ─── URLs ─────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_AUTHENTICATED_MAX=100
RATE_LIMIT_AUTHENTICATED_WINDOW_MS=60000
RATE_LIMIT_ANONYMOUS_MAX=20
RATE_LIMIT_ANONYMOUS_WINDOW_MS=60000

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=edgeflow-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9090

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change-me-32-byte-encryption-key-for-prod
